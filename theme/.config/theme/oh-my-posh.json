{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "background": "#000000",
    "background_dark": "#000000",
    "blue": "#6dcae8",
    "blue_bright": "#7dd8f5",
    "comment": "#6a7d89",
    "cyan": "#60d1dc",
    "foreground": "#e1e3e4",
    "green": "#9cd57b",
    "purple": "#ba9cf3",
    "orange": "#f3a96a",
    "red": "#f76c7c",
    "selection": "#2d2e2e",
    "yellow": "#e5c463"
  },
  "secondary_prompt": {
    "template": "❯❯ ",
    "foreground": "#6a7d89"
  },
  "transient_prompt": {
    "template": "❯ ",
    "foreground": "#60d1dc"
  },
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "style": "full"
          },
          "foreground": "#6dcae8",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "branch_icon": "",
            "cache_duration": "none",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }}",
          "foreground": "#9cd57b",
          "type": "git",
          "style": "plain",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#e5c463{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f3a96a{{ end }}",
            "{{ if gt .Ahead 0 }}#7dd8f5{{ end }}",
            "{{ if gt .Behind 0 }}#ba9cf3{{ end }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_package_manager": true,
            "npm_icon": " <#f76c7c></> ",
            "yarn_icon": " <#7dd8f5></>"
          },
          "template": " {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}",
          "foreground": "#9cd57b",
          "type": "node",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "  {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}",
          "foreground": "#e5c463",
          "type": "python",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "  {{ .Full }}",
          "foreground": "#7dd8f5",
          "type": "go",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "  {{ .Full }}",
          "foreground": "#f3a96a",
          "type": "rust",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "  {{ .Full }}",
          "foreground": "#f3a96a",
          "type": "java",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "roundrock",
            "threshold": 500
          },
          "template": " {{ .FormattedMs }}",
          "foreground": "#6a7d89",
          "type": "executiontime",
          "style": "plain"
        },
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": " {{ if gt .Code 0 }}✗{{ else }}✓{{ end }}",
          "foreground": "#9cd57b",
          "type": "exit",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#f76c7c{{ end }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": " ❯",
          "foreground": "#60d1dc",
          "type": "text",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "time_format": "15:04:05"
          },
          "template": "{{ .CurrentDate | date .Format }} ",
          "foreground": "#6a7d89",
          "type": "time",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "charged_icon": "",
            "charging_icon": "",
            "discharging_icon": ""
          },
          "template": "{{ if not .Error }}{{ .Icon }} {{ .Percentage }}{{ end }} ",
          "foreground": "#9cd57b",
          "type": "battery",
          "style": "plain",
          "foreground_templates": [
            "{{if eq \"Charging\" .State.String}}#e5c463{{end}}",
            "{{if eq \"Discharging\" .State.String}}#f3a96a{{end}}",
            "{{if eq \"Full\" .State.String}}#9cd57b{{end}}"
          ]
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
