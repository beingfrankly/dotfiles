# bat configuration
# https://github.com/sharkdp/bat

# Set the theme to use for syntax highlighting
# Oxocarbon is not built-in, using similar dark theme
--theme="base16"

# Show line numbers, Git modifications and file header (but no grid)
--style="numbers,changes,header"

# Use italic text on the terminal (not supported on all terminals)
--italic-text=always

# Add mouse scrolling support in less (does not work with all terminals)
--pager="less -FR"

# Use C++ syntax highlighting for .ino files
--map-syntax "*.ino:C++"

# Use JavaScript syntax highlighting for TypeScript
--map-syntax "*.tsx:TypeScript"
--map-syntax "*.ts:TypeScript"

# Use JSON for various config files
--map-syntax ".ignore:Git Ignore"
--map-syntax ".gitignore:Git Ignore"
--map-syntax ".dockerignore:Git Ignore"
