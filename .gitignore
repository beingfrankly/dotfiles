# macOS
.DS_Store

# Secrets (never tracked)
zsh/.config/zsh/secrets-hfs.sh
git/.config/git/config-hfs

# Generated files
nvim/.config/nvim/lazy-lock.json
nvim/.config/nvim/plugin/
nvim/.config/nvim/spell/
zsh/.config/zsh/.zcompdump*
zsh/.config/zsh/.zcompcache/
zsh/.config/zsh/.zhistory
zsh/.config/zsh/.zsh_history
zsh/.config/zsh/.zsh_sessions/
zsh/.config/zsh/plugins/

# Karabiner auto-generated
karabiner/.config/karabiner/automatic_backups/

# Claude workspace files (any stow package; CLAUDE.md stays tracked because these are file/subdir rules, not a .claude/ dir rule)
**/.claude/settings.local.json
**/.claude/telemetry/
**/.claude/sessions/
**/.claude/projects/
**/.claude/logs/
**/.claude/cache/
**/.claude/history.jsonl

# Backup files
*.bak

# Editor/IDE
/.claude/
!claude/
