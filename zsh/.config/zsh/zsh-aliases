# Zellij session manager - one command for everything
  zj() {
    local switch_file="/tmp/zellij_switch_target"

    if [[ -n "$ZELLIJ" ]]; then
      # Inside Zellij - pick another session to switch to
      local session=$(zellij list-sessions 2>/dev/null | grep -v "^${ZELLIJ_SESSION_NAME}\$" | fzf --height 40% --reverse --prompt="Switch to: ")
      if [[ -n "$session" ]]; then
        echo "$session" > "$switch_file"
        zellij action detach
      fi
      return
    fi

    # Outside Zellij - show picker
    local sessions=$(zellij list-sessions 2>/dev/null)
    local selection=$(printf "%s\n%s" "$sessions" "[+] Create new session" | fzf --height 40% --reverse --prompt="Session: ")

    [[ -z "$selection" ]] && return

    if [[ "$selection" == "[+] Create new session" ]]; then
      local dir=$(zoxide query -i)
      [[ -z "$dir" ]] && return
      selection=$(basename "$dir")
      CWD="$dir" zellij --layout dev --session "$selection"
    else
      zellij attach --force-run-commands "$selection"
    fi

    # Handle chained switches (when zj is called inside sessions)
    while [[ -f "$switch_file" ]]; do
      selection=$(cat "$switch_file")
      rm "$switch_file"
      zellij attach --force-run-commands "$selection"
    done
  }

