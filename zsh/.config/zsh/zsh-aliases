# Find and preview files with fzf + bat
alias preview="fzf --preview 'bat --color=always --style=numbers --line-range=:500 {}'"

# Search in files and preview with bat
alias search="rg --color=always --line-number --no-heading --smart-case . | fzf --ansi --preview 'bat --color=always {1} --highlight-line {2}'"

