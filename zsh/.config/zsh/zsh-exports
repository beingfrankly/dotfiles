#!/usr/bin/env zsh
# Environment exports

# ===== Path Configuration =====
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.local/bin/lua-language-server/bin:$PATH"
export PATH="$HOME/.local/bin/jdtls/bin:$PATH"
# go-hfs: resolve binary from current git worktree, fallback to main
go-hfs() {
  local root=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -n "$root" && -x "$root/go-hfs/bin/go-hfs" ]]; then
    "$root/go-hfs/bin/go-hfs" "$@"
  elif [[ -x "$HOME/code/hfs/main/go-hfs/bin/go-hfs" ]]; then
    "$HOME/code/hfs/main/go-hfs/bin/go-hfs" "$@"
  else
    echo "go-hfs: binary not found — run 'make build' in go-hfs/" >&2
    return 1
  fi
}
# Homebrew — macOS: /opt/homebrew, Linux: /home/linuxbrew/.linuxbrew
if [[ -d /opt/homebrew ]]; then
  export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"
elif [[ -d /home/linuxbrew/.linuxbrew ]]; then
  export PATH="/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:$PATH"
fi
[[ -d "/Applications/Obsidian.app/Contents/MacOS" ]] && export PATH="/Applications/Obsidian.app/Contents/MacOS:$PATH"
export PATH="$HOME/code/hfs/*/mcp:$PATH"

# ===== Editor Configuration =====
export EDITOR='nvim'
export VISUAL='nvim'
export MANPAGER='nvim +Man!'
